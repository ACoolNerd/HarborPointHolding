# Deployment Configuration for Harbor Point Holding
# Copy this to .env.local and fill in your credentials

# ============ LOCAL DEVELOPMENT ============
NODE_ENV=development
PORT=3000
HOST=localhost

# ============ GITHUB PAGES ============
# Automatic on push to main branch
# URL: https://ACoolNerd.github.io/HarborPointHolding
GITHUB_REPO=ACoolNerd/HarborPointHolding
GITHUB_PAGES_BRANCH=gh-pages

# ============ FTP/SFTP DEPLOYMENT ============
# For hosting on shared server or VPS
FTP_HOST=your-domain.com
FTP_PORT=21
FTP_USER=cpanel-username
FTP_PASS=cpanel-password
FTP_REMOTE_PATH=/public_html/harborpoint

# ============ VERCEL DEPLOYMENT ============
# Automatic if connected to Vercel
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=

# ============ HUBSPOT CRM ============
HUBSPOT_PORTAL_ID=your_portal_id
HUBSPOT_FORM_GUID=your_form_guid

# ============ CALENDLY ============
CALENDLY_URL=https://calendly.com/kassandra/consultation

# ============ SECURITY ============
# Never commit .env.local — it's in .gitignore
# GitHub Actions uses GitHub Secrets instead:
# Settings → Secrets and variables → Actions → New repository secret
